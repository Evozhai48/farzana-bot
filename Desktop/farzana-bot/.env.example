# ── Anthropic ──────────────────────────────────────────────
ANTHROPIC_API_KEY=your_claude_api_key_here

# ── Twilio ─────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here

# Your Twilio WhatsApp number (format: +1415XXXXXXX)
TWILIO_WHATSAPP_NUMBER=+1415XXXXXXX

# ── Restaurant owner WhatsApp ───────────────────────────────
# Owner receives order alerts + complaint alerts here
# Format: +601XXXXXXXXX (Malaysian number)
OWNER_WHATSAPP_NUMBER=+601XXXXXXXXX

# ── Server ─────────────────────────────────────────────────
PORT=3000
